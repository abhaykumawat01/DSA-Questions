class Solution {
// here time complexity of this method is O((m+n)log(m+n))
public:
    double findMedianSortedArrays(vector<int>& nums1, vector<int>& nums2) {
        int n = nums1.size();
        int m = nums2.size();
        nums1.insert(nums1.end(),nums2.begin(),nums2.end());
        sort(nums1.begin(),nums1.end());
        int value = m+n;
        if(value%2==0)
            return (float)(nums1[(m+n)/2] + nums1[(m+n-2)/2])/2;
        else
        return nums1[(m+n)/2];
    }
};
